rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (
          (request.auth.token.email in ["peter2005ngouala@gmail.com", "peterngouala@gmail.com", "peter25ngouala@gmail.com"]) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin')
        );
    }

    function isAideOf(courtierId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('brokerId', '') == courtierId;
    }

    function isSpecialAide() {
      return isAuthenticated() && 
             (request.auth.token.email == "aide1courtier@gmail.com" || 
              request.auth.token.email == "courtier1@gmail.com" ||
              request.auth.uid == "XHRMWa6wjcU1XXe67vec2A14Pri1" ||
              request.auth.uid == "V8x8KeKKQGTVqaJ0XYhdIbMoM2r1");
    }

    function isAuthorizedToPublish() {
      return isAuthenticated() && 
        (isAdmin() || 
         isSpecialAide() ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'courtier' ||
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'aide_courtier')));
    }

    function isNotBlocked() {
      return !isAuthenticated() || 
             !exists(/databases/$(database)/documents/users/$(request.auth.uid)) || 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) != true;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role']) &&
             data.uid is string &&
             data.role in ['user', 'courtier', 'aide_courtier', 'admin'] &&
             (!('nom' in data) || data.nom is string) &&
             (!('prenom' in data) || data.prenom is string) &&
             (!('country' in data) || data.country is string) &&
             (!('favorites' in data) || data.favorites is list) &&
             (!('phone' in data) || data.phone is string) &&
             (!('isBlocked' in data) || data.isBlocked is bool) &&
             (!('affiliateClicks' in data) || data.affiliateClicks is number) &&
             (!('balance' in data) || data.balance is number) &&
             (!('transactions' in data) || data.transactions is list) &&
             (!('brokerId' in data) || data.brokerId is string);
    }

    function isValidListing(data) {
      let requiredFields = ['title', 'description', 'price', 'neighborhood', 'type', 'whatsapp', 'courtierId', 'images', 'videos', 'createdAt'];
      return data.keys().hasAll(requiredFields) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             data.price is number && data.price >= 0 &&
             (!('visitFee' in data) || (data.visitFee is number && data.visitFee >= 0)) &&
             (!('tags' in data) || (data.tags is list && data.tags.size() <= 20)) &&
             (!('proximity' in data) || (data.proximity is list && data.proximity.size() <= 20)) &&
             data.neighborhood is string &&
             data.type in ["Chambre étudiant", "Appartement", "Villa", "Logement Entier", "Studio", "Chambre", "Terrain", "Bureau", "Magasin"] &&
             (!('stayType' in data) || data.stayType is string) &&
             (!('lat' in data) || data.lat is number) &&
             (!('lng' in data) || data.lng is number) &&
             data.whatsapp is string &&
             data.images is list && data.images.size() <= 10 &&
             data.videos is list && data.videos.size() <= 5 &&
             (data.createdAt is timestamp || data.createdAt is string) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp || data.updatedAt is string || data.updatedAt == null) &&
             data.courtierId is string &&
             (!('isBoosted' in data) || data.isBoosted is bool) &&
             (!('boostUntil' in data) || data.boostUntil is timestamp || data.boostUntil is string) &&
             (!('isVerified' in data) || data.isVerified is bool) &&
             (!('commissionAideCourtier' in data) || data.commissionAideCourtier is number) &&
             (!('allowCollaboration' in data) || data.allowCollaboration is bool) &&
             (!('bedrooms' in data) || data.bedrooms is number) &&
             (!('bathrooms' in data) || data.bathrooms is number) &&
             (!('courtierName' in data) || data.courtierName is string) &&
             (!('courtierPhoto' in data) || data.courtierPhoto is string) &&
             (!('status' in data) || data.status is string) &&
             (!('views' in data) || data.views is number) &&
             (!('favorites' in data) || data.favorites is number) &&
             (!('favoritesCount' in data) || data.favoritesCount is number);
    }

    function isValidReview(data) {
      return data.keys().hasAll(['courtierId', 'userId', 'userName', 'rating', 'comment', 'createdAt']) &&
             data.courtierId is string &&
             data.userId is string &&
             data.userName is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() < 1000 &&
             data.createdAt is timestamp;
    }

    function isValidServiceRequest(data) {
      return data.keys().hasAll(['userId', 'userEmail', 'serviceType', 'price', 'status', 'createdAt']) &&
             data.userId is string &&
             data.userEmail is string &&
             data.serviceType in ["Badge VÉRIFIÉ", "BOOST Semaine", "BOOST Mois", "PACK Agence", "Pack Découverte", "Boost Flash 24h"] &&
             data.price is number &&
             data.status in ["En attente", "Validé"] &&
             data.createdAt is timestamp &&
             (!('paymentMethod' in data) || data.paymentMethod in ["Wallet", "Manual"]);
    }

    function isValidHousingRequest(data) {
      return data.keys().hasAll(['userId', 'userName', 'neighborhood', 'type', 'budget', 'description', 'whatsapp', 'createdAt', 'status']) &&
             data.userId is string &&
             data.userName is string &&
             data.neighborhood is string &&
             data.type in ["Chambre étudiant", "Appartement", "Villa", "Logement Entier"] &&
             data.budget is number && data.budget > 0 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 1000 &&
             data.whatsapp is string && data.whatsapp.size() > 0 &&
             data.createdAt is timestamp &&
             data.status in ["Ouvert", "Fermé"] &&
             (!('userPhoto' in data) || data.userPhoto is string);
    }

    function isValidLeadTransfer(data) {
      return data.keys().hasAll(['listingId', 'listingTitle', 'affiliateId', 'affiliateName', 'courtierId', 'courtierName', 'createdAt']) &&
             data.listingId is string &&
             data.listingTitle is string &&
             data.affiliateId is string &&
             data.affiliateName is string &&
             data.courtierId is string &&
             data.courtierName is string &&
             data.createdAt is timestamp &&
             (!('clientName' in data) || (data.clientName is string || data.clientName == null));
    }

    function isValidRechargeRequest(data) {
      return data.keys().hasAll(['userId', 'amount', 'tarifChoisi', 'captureUrl', 'status', 'createdAt']) &&
             data.userId is string &&
             data.amount is number &&
             data.tarifChoisi is number &&
             data.captureUrl is string &&
             data.status in ['en_attente', 'valide', 'rejete'] &&
             data.createdAt is timestamp &&
             (!('userName' in data) || data.userName is string) &&
             (!('userEmail' in data) || data.userEmail is string);
    }

    function isValidWithdrawalRequest(data) {
      return data.keys().hasAll(['userId', 'amount', 'method', 'status', 'createdAt', 'phoneNumber', 'firstName', 'lastName']) &&
             data.userId is string &&
             data.amount is number && data.amount >= 5000 &&
             data.method in ['Wave', 'Orange Money'] &&
             data.phoneNumber is string && data.phoneNumber.size() >= 9 &&
             data.firstName is string && data.firstName.size() > 0 &&
             data.lastName is string && data.lastName.size() > 0 &&
             data.status in ['en_attente', 'valide', 'rejete'] &&
             data.createdAt is timestamp &&
             (!('userName' in data) || data.userName is string) &&
             (!('userEmail' in data) || data.userEmail is string);
    }

    function isValidBoostRequest(data) {
      return data.keys().hasAll(['listingId', 'courtierId', 'amount', 'duration', 'status', 'createdAt', 'serviceName', 'startDate', 'startTime', 'startDateTime']) &&
             data.listingId is string &&
             data.courtierId is string &&
             data.amount is number &&
             data.duration is number &&
             data.serviceName is string &&
             data.startDate is string &&
             data.startTime is string &&
             data.startDateTime is string &&
             data.status in ['en_attente', 'valide', 'rejete', 'approuve_programme', 'actif'] &&
             data.createdAt is timestamp &&
             (!('listingTitle' in data) || data.listingTitle is string) &&
             (!('courtierName' in data) || data.courtierName is string) &&
             (!('promoCode' in data) || (data.promoCode is string || data.promoCode == null));
    }

    function isValidPromoCode(data) {
      return data.keys().hasAll(['codeName', 'reduction', 'reductionType', 'dateExpiration', 'estActif', 'createdAt']) &&
             data.codeName is string &&
             data.reduction is number &&
             data.reductionType in ['percent', 'fixed'] &&
             (data.dateExpiration is timestamp || data.dateExpiration is string) &&
             data.estActif is bool &&
             data.createdAt is timestamp &&
             (!('afficherBarreDefilante' in data) || data.afficherBarreDefilante is bool);
    }

    function isValidVideoAccessRequest(data) {
      return data.keys().hasAll(['userId', 'userEmail', 'type', 'amount', 'status', 'createdAt']) &&
             data.userId is string &&
             data.userEmail is string &&
             data.type in ['single', 'business'] &&
             data.amount is number &&
             data.status in ['en_attente', 'valide', 'rejete'] &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAdmin() || 
                    (isOwner(userId) && isValidUser(request.resource.data) && 
                     request.resource.data.role == resource.data.role &&
                     // Protect balance and transactions from user modification
                     request.resource.data.get('balance', resource.data.get('balance', 0)) == resource.data.get('balance', 0) &&
                     request.resource.data.get('transactions', resource.data.get('transactions', [])) == resource.data.get('transactions', []) &&
                     request.resource.data.get('isBlocked', resource.data.get('isBlocked', false)) == resource.data.get('isBlocked', false)) ||
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['affiliateClicks', 'favorites']) && isOwner(userId));
      allow delete: if isAdmin();
    }

    match /admin_alerts/{alertId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.token.email in ["peter2005ngouala@gmail.com", "peterngouala@gmail.com", "peter25ngouala@gmail.com"]);
      allow create: if false; // Only via server-side
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /affiliate_clicks/{clickId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated(); // Anyone can trigger a click record
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (isAdmin() || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated(); // Courtiers can create notifications for affiliates
      allow update: if isAuthenticated() && (isAdmin() || (resource.data.userId == request.auth.uid && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read'])));
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /commission_claims/{claimId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource.data.affiliateId == request.auth.uid || resource.data.courtierId == request.auth.uid));
      allow create: if isAuthenticated(); // Affiliates can create claims
      allow update: if isAdmin(); // Only admin can update status
      allow delete: if isAdmin(); // Only admin can delete
    }

    match /listings/{listingId} {
      allow read: if true;
      allow create: if isNotBlocked() && isAuthorizedToPublish() && isValidListing(request.resource.data) && 
                      (request.resource.data.courtierId == request.auth.uid || isAideOf(request.resource.data.courtierId) || isSpecialAide());
      allow update: if isAdmin() || 
                      (isNotBlocked() && 
                        (resource.data.courtierId == request.auth.uid || isAideOf(resource.data.courtierId) || isSpecialAide()) && 
                        (isValidListing(request.resource.data) || 
                         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'views', 'favorites', 'favoritesCount', 'isBoosted', 'boostUntil', 'boostExpiresAt', 'updatedAt'])));
      allow delete: if (isAuthenticated() && (resource.data.courtierId == request.auth.uid || isAideOf(resource.data.courtierId) || isSpecialAide())) || isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isNotBlocked() && isValidReview(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid;
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /{path=**}/colocation_messages/{messageId} {
      allow read, write: if true;
    }

    match /service_requests/{requestId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated() && isValidServiceRequest(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid &&
                      (request.resource.data.status == "En attente" || request.resource.data.status == "Validé");
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /housing_requests/{requestId} {
      allow read, list: if isAuthenticated();
      allow create: if isAuthenticated() && isNotBlocked() && isValidHousingRequest(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || 
                      (isAuthenticated() && isNotBlocked() && resource.data.userId == request.auth.uid && 
                        isValidHousingRequest(request.resource.data));
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /lead_transfers/{transferId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource.data.affiliateId == request.auth.uid || resource.data.courtierId == request.auth.uid || isAideOf(resource.data.courtierId)));
      allow create: if isAuthenticated() && isValidLeadTransfer(request.resource.data) && 
                      request.resource.data.affiliateId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /recharge_requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidRechargeRequest(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.status == 'en_attente';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /withdrawal_requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidWithdrawalRequest(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.status == 'en_attente';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /demandes_boost/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.courtierId == request.auth.uid);
      allow create: if isAuthenticated() && isValidBoostRequest(request.resource.data) && 
                      request.resource.data.courtierId == request.auth.uid &&
                      request.resource.data.status == 'en_attente';
      allow update, delete: if isAdmin();
    }

    match /promo_codes/{codeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /video_access_requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && isValidVideoAccessRequest(request.resource.data) && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.status == 'en_attente';
      allow update, delete: if isAdmin();
    }
  }
}
